<script>
    /* ---------- Build share links once DOM is ready ---------- */
    const blogURL = window.location.href;
    const encodedURL = encodeURIComponent(blogURL);
    const encodedTitle = encodeURIComponent(document.title);   // page <title>

    /* LinkedIn (already working) */
    document.getElementById('linkedinShare').href =
        `https://www.linkedin.com/feed/?shareActive=true&shareUrl=${encodedURL}`;

    /* Facebook – simple, no app‑id needed */
    document.getElementById('facebookShare').href =
        `https://www.facebook.com/sharer/sharer.php?u=${encodedURL}`;

    /* X (Twitter) – title + link */
    document.getElementById('twitterShare').href =
        `https://x.com/intent/post?url=${encodedURL}&text=${encodedTitle}`;
</script>
