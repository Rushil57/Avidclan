                        <div class="col form-group">
                            <textarea name="message" id="message" class="contact_input px-0 contact_msg" placeholder="Message..." maxlength="500"></textarea>
                        </div>

                        <div class="col form-group">
                            <div class="btn-box mt-3">
                                @*<a href="https://www.avidclan.com/services#project_inquiry_form" class="theme-btn">*@
                                <button type="submit" name="submit" id="btnSubmit" class="theme-btn">
                                    <span class="btn-title">
                                        Send Message
                                        <span class="iconify ms-1" data-icon="line-md:email" data-height="25"></span>
                                        <div id="button-spinner" style="margin-left: 10px; width: 15px; height: 15px; display: none" class="spinner-border"></div>
