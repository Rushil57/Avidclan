<section id="process" class="process-section">
    <div class="container">
        <div class="text-center" style="margin-bottom:20px;">
            <h2 class="section-title">Hire in 4 Simple Steps</h2>
            <p class="section-subtitle">Streamlined process to get you coding faster.</p>
        </div>

        <div class="process-wrapper">
            <!-- Step 1 -->
            <div class="process-card">
                <div class="icon-container">
                    <img src="~/assets/src/images/message-search.svg" alt="Share requirements" class="step-icon">
                </div>
                <div class="card-text">
                    <h4>Share requirements</h4>
                    <p>Tell us what you need</p>
                </div>
            </div>

            <div class="process-arrow"><img src="~/assets/src/images/right-qrrow-lp.svg" alt=""></div>

            <!-- Step 2 -->
            <div class="process-card">
                <div class="icon-container">
                    <img src="~/assets/src/images/file-cv.svg" alt="Share requirements" class="step-icon">
                </div>
                <div class="card-text">
                    <h4>Review CVs</h4>
                    <p>Get top 3 profiles in 24h</p>
                </div>
            </div>

            <div class="process-arrow"><img src="~/assets/src/images/right-qrrow-lp.svg" alt=""></div>

            <!-- Step 3 -->
            <div class="process-card">
                <div class="icon-container">
                    <img src="~/assets/src/images/video-minus.svg" alt="Share requirements" class="step-icon">
                </div>
                <div class="card-text">
                    <h4>Interview</h4>
                    <p>Assess skills yourself</p>
                </div>
            </div>

            <div class="process-arrow"><img src="~/assets/src/images/right-qrrow-lp.svg" alt=""></div>

            <!-- Step 4 -->
            <div class="process-card">
                <div class="icon-container">
                    <img src="~/assets/src/images/coin-off.svg" alt="Share requirements" class="step-icon">
                </div>
                <div class="card-text">
                    <h4>Start Trial</h4>
                    <p>14-Day risk-free period</p>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- WHY US -->
<section id="why" class="why-us-section">
