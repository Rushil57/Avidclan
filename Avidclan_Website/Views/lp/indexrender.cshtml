<meta name="robots" content="noindex, nofollow" />


<!-- HERO SECTION -->
<section class="hero-section">
    <div class="container hero-grid">
        <!-- Left Text -->
        <div class="text-center text-center-md-left">
            <div class="badge">
                <!-- Star Icon -->
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                Top Rated .NET Agency
            </div>

            <h1 class="hero-title">
                Hire Expert .NET Developers in India
            </h1>

            <h2 class="hero-price">
                Starts at <span>&#8377;799/hr</span>
            </h2>

            <div class="feature-list" style="display: inline-flex; align-items: flex-start;">
                <div class="feature-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    No Upfront Payment
                </div>
                <div class="feature-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    6+ Years Average Experience
                </div>
                <div class="feature-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    14-Day Risk-Free Trial
                </div>
            </div>

            <div class="hero-buttons">
                <button onclick="navigateToSection('form')" class="btn btn-primary" style="padding: 1rem 2rem; font-size: 1.125rem;">
                    GET PROFILES
                    <!-- Arrow Right -->
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </button>
                <a href="tel:+919558450670" class="btn btn-outline desktop-cta" style="padding: 1rem 2rem; display: none;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                    +91 95584 50670
                </a>
            </div>

            <!-- Mobile Only Text Link -->
            <div style="display: block; margin-bottom: 1.5rem;" class="mobile-icons">
                <a href="tel:+919558450670" style="color: var(--secondary-blue); font-weight: 600; text-decoration: underline;">Or Call Us: +91 95584 50670</a>
            </div>


            <!-- Trusted By (Top Center) -->
            <div style="width:100%; display:flex; align-items:center; gap:4px; margin-bottom:6px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="#6b7280" stroke="none">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                </svg>
                <span style="font-weight:700;">Trusted By</span>
            </div>
            <div class="trust-strip">



                <!-- Logos (Same as before) -->
                <img class="logo-width" src="~/assets/src/images/relince.svg" alt="Reliance" />
                <img class="logo-width" src="~/assets/src/images/manappuram.svg" alt="Mannapuram Finance" />
                <img class="logo-width" src="~/assets/src/images/bajaj.svg" alt="Bajaj Allianz" />
                <img class="logo-width" src="~/assets/src/images/rocketfuel.svg" alt="RocketFuel" />
                <img class="logo-width" src="~/assets/src/images/tennessee.svg" alt="TVA" />

            </div>

        </div>




        <!-- Right Visual (Desktop Only) -->
        <div class="desktop-visual-container">
            <!-- PLACEHOLDER IMAGE FOR DEVELOPER VISUAL -->
            <!-- Replace src with your actual image file -->
            <img src="~/assets/src/images/developer.jpg" alt="Developer Visual Placeholder" class="desktop-visual-img" />

            <!-- Floating Badges Over Image -->
            <div class="float-badge" style="bottom: -20px; left: -20px;">
                <div class="fb-icon" style="background: #dbeafe;">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
                </div>
                <div>
                    <div style="font-weight: 700; font-size: 0.875rem;">Dedicated</div>
                    <div style="font-size: 0.75rem; color: #6b7280;">Resource</div>
                </div>
            </div>

            <div class="float-badge" style="top: -20px; right: -20px;">
                <div class="fb-icon" style="background: #ffedd5;">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ea580c" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                </div>
                <div>
                    <div style="font-weight: 700; font-size: 0.875rem;">Fast</div>
                    <div style="font-size: 0.75rem; color: #6b7280;">Onboarding</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- PRICING -->
<section id="pricing" class="section-pricing">
    <div class="container">
        <div class="text-center">
            <h2 style="font-size: 2rem; color: var(--primary-blue); font-weight: 700; margin-bottom: 0.5rem;">Transparent Pricing. No Hidden Costs.</h2>
            <p style="color: var(--text-muted); padding-bottom: 16px;">No hidden costs. Scale up or down.</p>
        </div>

        <div class="pricing-grid">
            <!-- Hourly -->
            <div class="pricing-card">
                <h3 style="font-size: 1.25rem; font-weight: 700; color: var(--text-muted);">Hourly</h3>
                <div class="price-tag">&#8377;799 <span style="font-size: 0.875rem; font-weight: 400; color: var(--text-muted);">/Hr</span></div>
                <ul class="pricing-features">
                    <li><div class="dot-bullet"></div> Pay As You Go</li>
                    <li><div class="dot-bullet"></div> Weekly Billing</li>
                    <li><div class="dot-bullet"></div> Best for Maintenance</li>
                </ul>
                <button onclick="navigateToSection('form')" class="btn btn-outline" style="width: 100%;">Inquire Now</button>
            </div>

            <!-- Monthly (Recommended) -->
            <div class="pricing-card popular">
                <div class="popular-badge">Most Popular</div>
                <h3 style="font-size: 1.25rem; font-weight: 700; color: var(--text-muted);">Monthly</h3>
                <div class="price-tag">&#8377;1.5 Lac <span style="font-size: 0.875rem; font-weight: 400; color: var(--text-muted);">/Mo</span></div>
                <ul class="pricing-features">
                    <li style="font-weight: 700; color: var(--primary-blue);">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                        Dedicated Developer
                    </li>
                    <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg> 160 Hours Guaranteed</li>
                    <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg> Direct Control</li>
                </ul>
                <button onclick="navigateToSection('form')" class="btn btn-secondary" style="width: 100%; background-color: var(--primary-blue);">Start 14-Day Trial</button>
            </div>

            <!-- Fixed -->
            <div class="pricing-card">
                <h3 style="font-size: 1.25rem; font-weight: 700; color: var(--text-muted);">Fixed Cost</h3>
                <div class="price-tag">Custom</div>
                <ul class="pricing-features">
                    <li><div class="dot-bullet"></div> Project Based</li>
                    <li><div class="dot-bullet"></div> Milestone Payments</li>
                    <li><div class="dot-bullet"></div> Defined Scope</li>
                </ul>
                <button onclick="navigateToSection('form')" class="btn btn-outline" style="width: 100%;">Get Quote</button>
            </div>
        </div>
    </div>
</section>

