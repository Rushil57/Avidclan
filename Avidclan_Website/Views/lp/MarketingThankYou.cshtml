
@{
    ViewBag.Title = "MarketingThankYou";
    Layout = "~/Views/Shared/MarketingLayout.cshtml";

}



<title>Thank you | Your message has been received</title>
<meta name="description" content="Thank you for contacting us. We'll get back to you soon." />
<link rel="canonical" href="https://www.avidclan.com/contact-us-thank-you/" />
<meta name="robots" content="noindex, nofollow" />
<script>/**
   * AVIDCLAN ENHANCED CONVERSION TRACKING
   * Retrieves the email from browser memory so GTM can read it.
   */
  var avid_user_email = localStorage.getItem("avid_user_email_storage") || "";</script>
<style>
    .marketing-thankyou {
        padding: 120px 0 60px 0;
}

.thankyou-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
}

.text-section {
    flex: 1 1 60%;
    text-align: left;
}

.text-section h1 {
    font-size: 48px;
    font-weight: 700;
    margin-bottom: 15px;
}

.text-section .primary-color {
    color: #0E53BE; /* your brand blue */
}

.text-section .text {
    font-size: 18px;
    margin-bottom: 25px;
    color: #333;
}

.image-section {
    flex: 1 1 35%;
    text-align: right;
}

.image-section img {
    max-width: 100%;
    height: auto;
}


    }
</style>
<section class="inner-page marketing-thankyou">
    <div class="container">
        <div class="thankyou-content">
            <div class="text-section">
                <h1><span class="primary-color">Thank</span> You!</h1>
                <p class="text">Thank you for your inquiry. We will get back to you soon.</p>

                <a href="~/lp/hire-dot-net-developer-india"
                   class="btn btn-primary fw-bold rounded-5 custom-btn-padding shadow-none">
                    <span>
                        <span class="iconify me-2" data-icon="entypo:arrow-long-left" data-height="25"></span>
                        Go to Home Page
                    </span>
                </a>
            </div>

            <div class="image-section">
                <img src="~/assets/images/contact-us-img.svg" alt="Thank You" class="img-fluid" />
            </div>
        </div>
    </div>
</section>



