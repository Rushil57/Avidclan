    @{
        // 1. Get the URL without the query string (e.g. ignores ?gad_source=1)
        string cleanCanonical = Request.Url.GetLeftPart(UriPartial.Path);
        // 2. Ensure the canonical URL ends with a slash
        if (!cleanCanonical.EndsWith("/"))
        {
            cleanCanonical += "/";
        }
    }
    <link rel="canonical" href="@cleanCanonical" />
