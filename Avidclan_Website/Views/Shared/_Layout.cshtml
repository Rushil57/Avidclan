    <script>

        /**

         * AVIDCLAN ENHANCED CONVERSION TRACKING

         * This script listens for user input in any of the specific email fields

         * (email, Email1, formemail) and saves the value to browser memory.

         */

        (function () {

            // Array of all Email Input IDs found on the website forms

            var targetEmailIds = ['email', 'Email1', 'formemail'];

            document.addEventListener('input', function (event) {

                // Check if the user is typing in one of our target email fields

                if (targetEmailIds.includes(event.target.id)) {

                    localStorage.setItem("avid_user_email_storage", event.target.value);

                }

            });

        })();
    </script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const navItems = document.querySelectorAll('.nhm-nav-item');

            navItems.forEach(item => {
                item.addEventListener('mouseenter', function (e) {
                    e.preventDefault();

                    // Find the parent container to scope the changes
                    const container = this.closest('.nhm-main-container');
                    if (!container) return;

                    // 1. Sidebar se 'active' class sirf is container ke andar hatao
                    container.querySelectorAll('.nhm-nav-item').forEach(nav => nav.classList.remove('active'));

                    // 2. Jis par hover kiya usse 'active' karo
                    this.classList.add('active');

                    // 3. Right side ke saare content sections sirf is container ke andar hide karo
                    container.querySelectorAll('.nhm-tab-content').forEach(content => {
                        content.style.display = 'none';
                    });

                    // 4. Targeted section ko show karo
                    const targetId = this.getAttribute('data-target');
                    const targetElement = container.querySelector('#' + targetId);
                    if (targetElement) {
                        targetElement.style.display = 'block';
                    }
                });
            });
        });
    </script>
