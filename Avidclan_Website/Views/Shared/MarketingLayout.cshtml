    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script>
        $(document).ready(function () {

            // ---------- Scroll to form ----------
            $("a[href='#form']").on("click", function (e) {
                e.preventDefault();
                $('html, body').animate({
                    scrollTop: $("#form").offset().top - 50
                }, 500, function () {
                    $("#formname").focus();
                });
            });

            // ---------- Validation ----------
            $("#myForm").validate({
                rules: {
                    formname: {
                        required: true,
                        minlength: 2
                    },
                    formemail: {
                        required: true,
                        email: true
                    },
                    formnumber: {
                        required: true,
                        minlength: 10,
                        maxlength: 15
                    },
                    formservice: {
                        required: true
                    },
                    formbudget: {
                        required: true
                    },
                    formtextarea: {
                        required: true,
                        minlength: 15
                    }
                },
                messages: {
                    formname: {
                        required: "Please enter your name",
                        minlength: "Name must be at least 2 letters"
                    },
                    formemail: {
                        required: "Please enter your email",
                        email: "Enter a valid email address"
                    },
                    formnumber: {
                        required: "Please enter your phone number",
                        minlength: "Phone number must be at least 10 digits",
                        maxlength: "Phone number cannot exceed 15 digits"
                    },
                    formservice: {
                        required: "Please select a service"
                    },
                    formbudget: {
                        required: "Please select your budget"
                    },
                    formtextarea: {
                        required: "Please describe your requirements",
                        minlength: "Please enter at least 15 characters"
                    }
                }
            });

            // ---------- Phone max length ----------
            $("#formnumber").on("input", function () {
                let value = $(this).val();
                if (value.length > 15) {
                    $(this).val(value.slice(0, 15));
                }
            });

            // ---------- Submit ----------
            $("#btnInquire").on("click", function (e) {
                e.preventDefault();

                if (!$("#myForm").valid()) return;

                $("#btnInquire")
                    .text("Submitting...")
                    .addClass("btn-loading")
                    .prop("disabled", true);

                const gclid = sessionStorage.getItem("gclid");

                var data = {
                    FirstName: $("#formname").val(),
                    Email: $("#formemail").val(),
                    Phoneumber: $("#formnumber").val(),
                    Service: $("#formservice").val(),
                    Budget: $("#formbudget").val(),
                    Message: $("#formtextarea").val(),
                    Gclid: gclid
                };


                $.ajax({
                    type: "POST",
                    url: "/api/Mail/SendEmailMarketingPage",
                    contentType: "application/json",
                    data: JSON.stringify(data),
                    success: function (response) {
                        if (response === "Sent" || response?.status === "Sent") {
                            window.location.href = "/lp/thank-you/";
                        } else {
                            alert("Something went wrong. Please try again.");
                        }
                        $("#myForm")[0].reset();
                    },
                    error: function () {
                        alert("Something went wrong. Please try again later.");
                    },
                    complete: function () {
                        $("#btnInquire")
                            .text("SHOW ME PROFILES")
                            .removeClass("btn-loading")
                            .prop("disabled", false);
                    }
                });
            });

        });
    </script>

    <script>
        const INDEX_PAGE_PATH = "/lp/hire-dot-net-developer-india";

        function isIndexPage() {
            return window.location.pathname === INDEX_PAGE_PATH
                || window.location.pathname === INDEX_PAGE_PATH + "/";
        }

        function navigateToSection(id, slug = id) {

            if (isIndexPage()) {
                // ✅ Same page → smooth scroll
                const el = document.getElementById(id);
                if (!el) return;

                el.scrollIntoView({ behavior: "smooth" });
                history.pushState(null, "", "#" + slug);
            } else {
                // ✅ Other pages (thank-you etc.) → redirect to LP
                window.location.href = INDEX_PAGE_PATH + "#" + slug;
            }
        }

        /* --------- Direct URL open support --------- */
        window.addEventListener("load", function () {
            if (!isIndexPage()) return;

            const hash = window.location.hash.replace("#", "");

            const hashMap = {
                "pricing": "pricing",
                "tech-stack": "tech",
                "process": "process",
                "why-us": "why",
                "form": "form"
            };

            if (hashMap[hash]) {
                const target = document.getElementById(hashMap[hash]);
                if (target) {
                    setTimeout(() => {
                        target.scrollIntoView({ behavior: "smooth" });
                    }, 200);
                }
            }
        });
    </script>


    <script>
        function toggleFaq(button) {
            const item = button.parentElement;
            const content = item.querySelector('.faq-content');

            item.classList.toggle('active');

            if (item.classList.contains('active')) {
                content.style.maxHeight = content.scrollHeight + "px";
            } else {
                content.style.maxHeight = null;
            }
        }
        function navigateToSection(id, slug = id) {

            if (isIndexPage()) {
                const el = document.getElementById(id);
                if (!el) return;

                const yOffset = -70;
                const y = el.getBoundingClientRect().top + window.pageYOffset + yOffset;

                window.scrollTo({
                    top: y,
                    behavior: "smooth"
                });

                history.pushState(null, "", "#" + slug);
            } else {
                window.location.href = INDEX_PAGE_PATH + "#" + slug;
            }
        }

    </script>

