    <script>
        document.addEventListener("DOMContentLoaded", function () { let e = document.getElementById("navbarSupportedContent"); if (e) { e.addEventListener("show.bs.collapse", () => { document.body.classList.add("mobile-menu-open") }), e.addEventListener("hide.bs.collapse", () => { document.body.classList.remove("mobile-menu-open") }); let t = document.querySelectorAll(".mobile-arrow-icon"); t.forEach(l => { l.addEventListener("click", function () { let s = this.querySelector(".arrow-icon-img"); if (s) { let i = this.getAttribute("aria-expanded") === "true"; s.style.transform = i ? "rotate(0deg)" : "rotate(180deg)", s.style.transition = "transform 0.3s ease" } }); let r = l.closest(".dropdown"); r && r.addEventListener("hide.bs.dropdown", () => { let s = l.querySelector(".arrow-icon-img"); s && (s.style.transform = "rotate(0deg)") }) }) } let o = document.querySelectorAll(".filter-tabs .filter"), a = document.querySelectorAll(".items-container .masonry-item"); if (o.length > 0 && a.length > 0) { o.forEach(l => { l.addEventListener("click", function () { o.forEach(s => s.classList.remove("active")), this.classList.add("active"); let i = this.getAttribute("data-filter"); a.forEach(r => { r.style.display = r.classList.contains(i.substring(1)) ? "block" : "none" }) }) }); let c = document.querySelector(".filter-tabs .filter.active"); c && c.click() } let n = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]')); n.map(t => new bootstrap.Tooltip(t)) });

        // Header shadow toggle on scroll
        const header = document.querySelector(".custom-new-shadow");
        if (header) {
            window.addEventListener("scroll", () => {
                header.classList.toggle("scrolled", window.scrollY > 50);
            });
        }

        document.addEventListener("DOMContentLoaded", function () {
            const navItems = document.querySelectorAll('.nhm-nav-item');

            navItems.forEach(item => {
                item.addEventListener('mouseenter', function (e) {
                    e.preventDefault();

                    // Find the parent container to scope the changes
                    const container = this.closest('.nhm-main-container');
                    if (!container) return;

                    // 1. Remove the 'active' class from the sidebar within this container
                    container.querySelectorAll('.nhm-nav-item').forEach(nav => nav.classList.remove('active'));

                    // 2. Add the 'active' class to the hovered item
                    this.classList.add('active');

                    // 3. Hide all right-side content sections within this container
                    container.querySelectorAll('.nhm-tab-content').forEach(content => {
                        content.style.display = 'none';
                    });

                    // 4. Show the targeted section
                    const targetId = this.getAttribute('data-target');
                    const targetElement = container.querySelector('#' + targetId);
                    if (targetElement) {
                        targetElement.style.display = 'block';
                    }
                });
            });
        });
    </script>
